<!DOCTYPE html>
<html lang="sw">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nilongo Digital Garden — Bustani ya Maarifa na Hekima</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Inter:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">

<style>
/* ══════════════════════════════════════════════
   TOKENS
══════════════════════════════════════════════ */
:root {
  --ink:        #06120b;
  --soil:       #0e1f14;
  --bark:       #152b1b;
  --moss:       #1c3d24;
  --leaf:       #2a6642;
  --sprout:     #3dba68;
  --glow:       #52f08a;
  --gold:       #d4a84b;
  --parchment:  #f0ead6;
  --fog:        rgba(255,255,255,0.06);
  --fog2:       rgba(255,255,255,0.10);
  --fog3:       rgba(255,255,255,0.16);
  --text:       #cce8d5;
  --text-dim:   #7aaa8a;
  --radius:     16px;
  --font-d:     'Playfair Display', Georgia, serif;
  --font-b:     'Inter', system-ui, sans-serif;
  --font-m:     'Space Mono', monospace;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  font-family: var(--font-b);
  background: var(--ink);
  color: var(--text);
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

/* ══════════════════════════════════════════════
   SCROLLBAR
══════════════════════════════════════════════ */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: var(--soil); }
::-webkit-scrollbar-thumb { background: var(--leaf); border-radius: 3px; }

/* ══════════════════════════════════════════════
   HERO
══════════════════════════════════════════════ */
.hero {
  min-height: 100vh;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 40px 24px;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  inset: 0;
  background:
    url('https://images.unsplash.com/photo-1448375240586-882707db888b?w=1800&q=80') center/cover no-repeat;
  filter: brightness(0.2) saturate(0.8);
  z-index: 0;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 70% 60% at 50% 50%, rgba(52,186,104,0.18) 0%, transparent 70%),
    linear-gradient(180deg, rgba(6,18,11,0.3) 0%, rgba(6,18,11,0.85) 100%);
  z-index: 1;
}

/* Animated roots */
.roots {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 200px;
  z-index: 2;
  pointer-events: none;
  background: linear-gradient(transparent, var(--ink));
}

.hero-content {
  position: relative;
  z-index: 3;
  max-width: 820px;
}

.eyebrow {
  font-family: var(--font-m);
  font-size: 11px;
  letter-spacing: 0.24em;
  color: var(--sprout);
  text-transform: uppercase;
  margin-bottom: 28px;
  opacity: 0.9;
}

.hero h1 {
  font-family: var(--font-d);
  font-size: clamp(40px, 7vw, 88px);
  font-weight: 900;
  line-height: 1.05;
  letter-spacing: -0.02em;
  color: var(--parchment);
  margin-bottom: 8px;
}

.hero h1 em {
  font-style: normal;
  color: var(--glow);
  text-shadow: 0 0 40px rgba(82,240,138,0.35);
}

.hero-sub {
  font-family: var(--font-d);
  font-size: clamp(16px, 2.5vw, 22px);
  color: var(--gold);
  font-style: italic;
  margin-bottom: 28px;
  opacity: 0.9;
  letter-spacing: 0.01em;
}

.hero-desc {
  font-size: 16px;
  line-height: 1.75;
  color: var(--text-dim);
  max-width: 580px;
  margin: 0 auto 44px;
}

.hero-cta {
  display: flex;
  gap: 16px;
  justify-content: center;
  flex-wrap: wrap;
}

.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 16px 36px;
  background: linear-gradient(135deg, var(--sprout), var(--glow));
  color: var(--ink);
  font-family: var(--font-b);
  font-weight: 700;
  font-size: 15px;
  border: none;
  border-radius: 50px;
  cursor: pointer;
  transition: transform 0.25s, box-shadow 0.25s;
  box-shadow: 0 0 30px rgba(82,240,138,0.3);
  text-decoration: none;
  letter-spacing: 0.01em;
}

.btn-primary:hover {
  transform: translateY(-3px) scale(1.04);
  box-shadow: 0 0 50px rgba(82,240,138,0.5);
}

.btn-ghost {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 15px 32px;
  background: transparent;
  color: var(--text);
  font-family: var(--font-b);
  font-weight: 500;
  font-size: 15px;
  border: 1px solid var(--fog3);
  border-radius: 50px;
  cursor: pointer;
  transition: border-color 0.25s, background 0.25s;
  text-decoration: none;
}

.btn-ghost:hover {
  border-color: var(--sprout);
  background: var(--fog);
  color: var(--sprout);
}

/* Scroll indicator */
.scroll-hint {
  position: absolute;
  bottom: 36px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  opacity: 0.5;
  animation: float 2.5s ease-in-out infinite;
}

.scroll-hint span {
  font-family: var(--font-m);
  font-size: 9px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.scroll-line {
  width: 1px;
  height: 48px;
  background: linear-gradient(var(--sprout), transparent);
  animation: growLine 2s ease-in-out infinite;
}

@keyframes float { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(8px)} }
@keyframes growLine { 0%,100%{opacity:0.3;height:32px} 50%{opacity:1;height:56px} }

/* Stats bar */
.stats-bar {
  display: flex;
  justify-content: center;
  gap: 40px;
  flex-wrap: wrap;
  margin-top: 64px;
  padding-top: 40px;
  border-top: 1px solid var(--fog2);
  position: relative;
  z-index: 3;
}

.stat-item { text-align: center; }
.stat-num {
  font-family: var(--font-d);
  font-size: 32px;
  font-weight: 900;
  color: var(--parchment);
  line-height: 1;
}
.stat-num em { color: var(--glow); font-style: normal; }
.stat-label {
  font-family: var(--font-m);
  font-size: 10px;
  letter-spacing: 0.18em;
  color: var(--text-dim);
  text-transform: uppercase;
  margin-top: 6px;
}

/* ══════════════════════════════════════════════
   NAV (visible when scrolled)
══════════════════════════════════════════════ */
.nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  padding: 0 32px;
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(6,18,11,0.85);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--fog);
  transform: translateY(-100%);
  transition: transform 0.4s ease;
}

.nav.visible { transform: translateY(0); }

.nav-logo {
  font-family: var(--font-d);
  font-size: 18px;
  font-weight: 700;
  color: var(--parchment);
}

.nav-logo em { color: var(--glow); font-style: normal; }

.nav-links {
  display: flex;
  gap: 32px;
  list-style: none;
}

.nav-links a {
  color: var(--text-dim);
  text-decoration: none;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.04em;
  transition: color 0.2s;
}

.nav-links a:hover { color: var(--sprout); }

.nav-btn {
  padding: 9px 22px;
  background: var(--sprout);
  color: var(--ink);
  font-weight: 700;
  font-size: 13px;
  border: none;
  border-radius: 50px;
  cursor: pointer;
  transition: background 0.2s;
}

.nav-btn:hover { background: var(--glow); }

/* ══════════════════════════════════════════════
   SECTIONS
══════════════════════════════════════════════ */
section {
  padding: 100px 24px;
  max-width: 1100px;
  margin: 0 auto;
}

.section-label {
  font-family: var(--font-m);
  font-size: 10px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--sprout);
  margin-bottom: 16px;
}

.section-title {
  font-family: var(--font-d);
  font-size: clamp(32px, 4.5vw, 56px);
  font-weight: 900;
  line-height: 1.1;
  color: var(--parchment);
  margin-bottom: 20px;
  letter-spacing: -0.02em;
}

.section-title em {
  font-style: italic;
  color: var(--glow);
}

.section-sub {
  font-size: 16px;
  line-height: 1.75;
  color: var(--text-dim);
  max-width: 600px;
}

/* ══════════════════════════════════════════════
   WHY / VALUES
══════════════════════════════════════════════ */
.why-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 20px;
  margin-top: 56px;
}

.why-card {
  background: var(--fog);
  border: 1px solid var(--fog2);
  border-radius: var(--radius);
  padding: 32px;
  transition: border-color 0.3s, transform 0.3s;
  position: relative;
  overflow: hidden;
}

.why-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 3px;
  height: 100%;
  background: linear-gradient(var(--sprout), var(--leaf));
  opacity: 0;
  transition: opacity 0.3s;
}

.why-card:hover {
  border-color: rgba(61,186,104,0.3);
  transform: translateY(-4px);
}

.why-card:hover::before { opacity: 1; }

.why-icon {
  font-size: 36px;
  margin-bottom: 20px;
  display: block;
}

.why-card h3 {
  font-family: var(--font-d);
  font-size: 22px;
  font-weight: 700;
  color: var(--parchment);
  margin-bottom: 12px;
}

.why-card p {
  font-size: 14px;
  line-height: 1.7;
  color: var(--text-dim);
}

/* ══════════════════════════════════════════════
   LIBRARY
══════════════════════════════════════════════ */
.library-bg {
  background: linear-gradient(var(--ink), var(--soil), var(--ink));
  padding: 100px 0;
}

.library-inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 24px;
}

.categories {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 16px;
  margin-top: 56px;
}

.cat-pill {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 20px 24px;
  background: var(--fog);
  border: 1px solid var(--fog2);
  border-radius: 12px;
  cursor: pointer;
  transition: all 0.25s;
  text-decoration: none;
}

.cat-pill:hover {
  background: rgba(61,186,104,0.1);
  border-color: rgba(61,186,104,0.4);
  transform: translateY(-2px);
}

.cat-icon { font-size: 26px; flex-shrink: 0; }

.cat-name {
  font-family: var(--font-b);
  font-size: 13px;
  font-weight: 600;
  color: var(--text);
  line-height: 1.3;
}

/* ══════════════════════════════════════════════
   JOURNEY / LEVELS
══════════════════════════════════════════════ */
.journey-path {
  position: relative;
  margin-top: 64px;
  padding-left: 56px;
}

.journey-path::before {
  content: '';
  position: absolute;
  left: 19px;
  top: 0; bottom: 0;
  width: 2px;
  background: linear-gradient(var(--sprout), var(--leaf), transparent);
}

.level-item {
  position: relative;
  margin-bottom: 48px;
  animation: fadeUp 0.5s ease both;
}

.level-dot {
  position: absolute;
  left: -45px;
  top: 6px;
  width: 22px;
  height: 22px;
  border-radius: 50%;
  border: 2px solid var(--leaf);
  background: var(--soil);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  transition: border-color 0.3s;
}

.level-item:hover .level-dot {
  border-color: var(--sprout);
  box-shadow: 0 0 12px rgba(61,186,104,0.4);
}

.level-name {
  font-family: var(--font-d);
  font-size: 22px;
  font-weight: 700;
  color: var(--parchment);
  margin-bottom: 6px;
}

.level-desc {
  font-size: 14px;
  color: var(--text-dim);
  line-height: 1.6;
}

.level-pts {
  font-family: var(--font-m);
  font-size: 11px;
  color: var(--gold);
  margin-top: 6px;
  letter-spacing: 0.1em;
}

/* ══════════════════════════════════════════════
   PRICING
══════════════════════════════════════════════ */
.pricing-wrap {
  display: flex;
  gap: 24px;
  justify-content: center;
  margin-top: 56px;
  flex-wrap: wrap;
}

.price-card {
  background: var(--fog);
  border: 1px solid var(--fog2);
  border-radius: 20px;
  padding: 40px 36px;
  max-width: 360px;
  width: 100%;
  position: relative;
  transition: transform 0.3s, border-color 0.3s;
}

.price-card:hover {
  transform: translateY(-6px);
}

.price-card.featured {
  border-color: rgba(61,186,104,0.5);
  background: linear-gradient(135deg, rgba(61,186,104,0.08), var(--fog));
}

.price-badge {
  position: absolute;
  top: -14px;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, var(--sprout), var(--glow));
  color: var(--ink);
  font-family: var(--font-m);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  padding: 6px 20px;
  border-radius: 50px;
  white-space: nowrap;
}

.price-plan {
  font-family: var(--font-m);
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: 16px;
}

.price-amount {
  font-family: var(--font-d);
  font-size: 52px;
  font-weight: 900;
  color: var(--parchment);
  line-height: 1;
  margin-bottom: 4px;
}

.price-amount span {
  font-size: 18px;
  font-weight: 400;
  color: var(--text-dim);
}

.price-period {
  font-size: 13px;
  color: var(--text-dim);
  margin-bottom: 28px;
}

.price-features {
  list-style: none;
  margin-bottom: 32px;
}

.price-features li {
  display: flex;
  gap: 12px;
  align-items: flex-start;
  font-size: 14px;
  color: var(--text);
  margin-bottom: 12px;
  line-height: 1.5;
}

.price-features li::before {
  content: '✓';
  color: var(--sprout);
  font-weight: 700;
  flex-shrink: 0;
  margin-top: 1px;
}

/* ══════════════════════════════════════════════
   PAYMENT METHODS
══════════════════════════════════════════════ */
.pay-methods {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  justify-content: center;
  margin-top: 32px;
}

.pay-pill {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 22px;
  background: var(--fog);
  border: 1px solid var(--fog2);
  border-radius: 10px;
  font-size: 14px;
  color: var(--text);
  cursor: pointer;
  transition: border-color 0.2s;
}

.pay-pill:hover { border-color: var(--gold); }
.pay-pill strong { color: var(--gold); font-family: var(--font-m); font-size: 12px; }

/* ══════════════════════════════════════════════
   LOGIN / DASHBOARD
══════════════════════════════════════════════ */
.login-screen {
  display: none;
  min-height: 100vh;
  align-items: center;
  justify-content: center;
  background: var(--ink);
  padding: 40px 24px;
  position: fixed;
  inset: 0;
  z-index: 200;
}

.login-box {
  background: var(--soil);
  border: 1px solid var(--fog2);
  border-radius: 24px;
  padding: 48px 44px;
  max-width: 420px;
  width: 100%;
  text-align: center;
  box-shadow: 0 40px 80px rgba(0,0,0,0.6);
  position: relative;
}

.login-box::before {
  content: '';
  position: absolute;
  top: 0; left: 50%;
  transform: translateX(-50%);
  width: 60%;
  height: 1px;
  background: linear-gradient(transparent, var(--sprout), transparent);
}

.login-logo {
  font-family: var(--font-d);
  font-size: 28px;
  font-weight: 900;
  color: var(--parchment);
  margin-bottom: 6px;
}

.login-logo em { color: var(--glow); font-style: normal; }

.login-tagline {
  font-family: var(--font-d);
  font-style: italic;
  color: var(--text-dim);
  font-size: 14px;
  margin-bottom: 36px;
}

.form-group {
  margin-bottom: 20px;
  text-align: left;
}

.form-group label {
  display: block;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.08em;
  color: var(--text-dim);
  text-transform: uppercase;
  margin-bottom: 8px;
}

.form-group input {
  width: 100%;
  padding: 14px 18px;
  background: var(--fog);
  border: 1px solid var(--fog2);
  border-radius: 12px;
  color: var(--parchment);
  font-family: var(--font-b);
  font-size: 15px;
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
}

.form-group input:focus {
  border-color: var(--sprout);
  box-shadow: 0 0 0 3px rgba(61,186,104,0.12);
}

.form-group input::placeholder { color: var(--text-dim); opacity: 0.6; }

.login-close {
  position: absolute;
  top: 20px; right: 20px;
  background: none;
  border: none;
  color: var(--text-dim);
  font-size: 22px;
  cursor: pointer;
  padding: 4px;
  line-height: 1;
  transition: color 0.2s;
}

.login-close:hover { color: var(--text); }

/* ══════════════════════════════════════════════
   DASHBOARD
══════════════════════════════════════════════ */
.dashboard-screen {
  display: none;
  min-height: 100vh;
  background: var(--ink);
  position: fixed;
  inset: 0;
  z-index: 200;
  overflow-y: auto;
}

.dash-layout {
  display: flex;
  min-height: 100vh;
}

/* Sidebar */
.dash-sidebar {
  width: 240px;
  min-height: 100vh;
  background: var(--soil);
  border-right: 1px solid var(--fog2);
  padding: 32px 20px;
  flex-shrink: 0;
  position: sticky;
  top: 0;
  height: 100vh;
  overflow-y: auto;
}

.dash-brand {
  font-family: var(--font-d);
  font-size: 18px;
  font-weight: 900;
  color: var(--parchment);
  margin-bottom: 4px;
}

.dash-brand em { color: var(--glow); font-style: normal; }

.dash-user-info {
  font-size: 12px;
  color: var(--text-dim);
  margin-bottom: 36px;
  padding-bottom: 24px;
  border-bottom: 1px solid var(--fog2);
}

.dash-user-name {
  font-size: 15px;
  font-weight: 600;
  color: var(--text);
  margin-top: 12px;
}

.dash-level-badge {
  display: inline-block;
  margin-top: 6px;
  padding: 3px 12px;
  background: rgba(61,186,104,0.12);
  border: 1px solid rgba(61,186,104,0.3);
  border-radius: 50px;
  font-family: var(--font-m);
  font-size: 10px;
  color: var(--sprout);
}

.nav-section-title {
  font-family: var(--font-m);
  font-size: 9px;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: var(--text-dim);
  opacity: 0.6;
  margin-bottom: 10px;
  margin-top: 24px;
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 11px 14px;
  border-radius: 10px;
  cursor: pointer;
  font-size: 14px;
  font-weight: 500;
  color: var(--text-dim);
  transition: all 0.2s;
  margin-bottom: 4px;
  border: none;
  background: none;
  width: 100%;
  text-align: left;
}

.nav-item:hover, .nav-item.active {
  background: rgba(61,186,104,0.1);
  color: var(--text);
}

.nav-item.active { color: var(--sprout); }

.nav-item .nav-icon { font-size: 18px; }

.nav-logout {
  margin-top: 32px;
  padding-top: 24px;
  border-top: 1px solid var(--fog2);
}

/* Main content */
.dash-main {
  flex: 1;
  padding: 36px 40px;
  min-width: 0;
}

.dash-header {
  margin-bottom: 36px;
}

.dash-greeting {
  font-family: var(--font-d);
  font-size: 32px;
  font-weight: 900;
  color: var(--parchment);
  margin-bottom: 4px;
}

.dash-greeting em { color: var(--glow); font-style: normal; }

.dash-date {
  font-family: var(--font-m);
  font-size: 11px;
